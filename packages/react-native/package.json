{
  "private": true,
  "name": "@canopy/react-native",
  "version": "0.2.0",
  "description": "React Native platform layer + adapters for the canopy agent SDK",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".":                              "./index.js",
    "./metro-preset":                 "./metro-preset.cjs",
    "./platform/polyfills": {
      "react-native": "./src/platform/polyfills.rn.js",
      "default":      "./src/platform/polyfills.js"
    },
    "./platform/service-factory":     "./src/platform/service-factory.js",
    "./platform/shims/node-builtins": "./src/platform/shims/node-builtins.js",
    "./platform/shims/path":          "./src/platform/shims/path.js",
    "./platform/shims/util":          "./src/platform/shims/util.js",
    "./platform/shims/ws":            "./src/platform/shims/ws.js",

    "./ports":                        "./src/ports/index.js",

    "./identity":                     "./src/identity/index.js",
    "./identity/bootstrap":           "./src/identity/bootstrapIdentity.js",
    "./identity/VaultAsyncStorage":   "./src/identity/VaultAsyncStorage.js",

    "./storage":                      "./src/storage/index.js",
    "./storage/AsyncStorageAdapter":  "./src/storage/AsyncStorageAdapter.js",
    "./pseudo-pod-adapter":           "./src/pseudo-pod-adapter/index.js",
    "./hub-discovery":                "./src/hub-discovery/index.js",
    "./hub-binding":                  "./src/hub-binding/index.js",

    "./picker":                       "./src/picker/index.js",
    "./qr":                           "./src/qr/index.js",
    "./qr/view":                      "./src/qr/QrCodeView.jsx",
    "./mnemonic":                     "./src/mnemonic/index.js",
    "./mnemonic/view":                "./src/mnemonic/MnemonicView.jsx",
    "./push":                         "./src/push/index.js",
    "./localisation":                         "./src/localisation/index.js",

    "./deepLinks":                    "./src/deepLinks/index.js",
    "./theme":                        "./src/theme/index.js",
    "./components":                   "./src/components/index.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@canopy/core": "^0.1.0",
    "@canopy/pod-client": "^0.1.0",
    "@canopy/transports": "^0.1.0",
    "@canopy/vault": "^0.1.0",
    "@react-native-async-storage/async-storage": "*",
    "react-native-ble-plx": "*",
    "react-native-keychain": "*",
    "react-native-get-random-values": "*",
    "buffer": "*",
    "nkn-multiclient": "*",
    "nkn-sdk": "*"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": { "optional": false },
    "react-native-ble-plx": { "optional": false },
    "react-native-keychain": { "optional": false },
    "react-native-get-random-values": { "optional": false },
    "buffer": { "optional": false },
    "nkn-multiclient": { "optional": true },
    "nkn-sdk": { "optional": true }
  },
  "devDependencies": {
    "@canopy/core": "file:../core",
    "@canopy/pod-client": "file:../pod-client",
    "react": "^19.0.0",
    "vitest": "^2.1.0"
  }
}
