{
  "private": true,
  "name": "@onderling/blob-gateway",
  "version": "0.1.0",
  "description": "Media substrate: client-side-encrypt a blob → untrusted bucket + a cross-pod-ref manifest line in the pod; a deny-by-default poortwachter (verifyToken → ACL → presigned URL). Bucket/token/acl are injected (cloud-agnostic).",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./adapters/s3": "./src/adapters/s3Bucket.js",
    "./adapters/solid-verifier": "./src/adapters/solidVerifier.js",
    "./adapters/capability-verifier": "./src/adapters/capabilityVerifier.js",
    "./adapters/pod-acl": "./src/adapters/podAcl.js",
    "./http": "./src/httpGate.js"
  },
  "scripts": {
    "test":       "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@onderling/core": "file:../core",
    "@onderling/oidc-session": "file:../oidc-session",
    "@onderling/pod-client": "file:../pod-client"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  }
}
