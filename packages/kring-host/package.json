{
  "private": true,
  "name":        "@onderling/kring-host",
  "version":     "0.1.0",
  "description": "The platform-neutral kring/circle HOST substrate — composition LOGIC shared by the web + mobile basis shells (repo-split W2, objective F). Depends DOWN on the kernel substrates (@onderling/item-store, @onderling/item-types); never up on an app. First extraction: the circle LISTS feature (makeCircleLists).",
  "type":        "module",
  "main":        "src/index.js",
  "exports": {
    ".":                "./src/index.js",
    "./circleLists":    "./src/circleLists.js",
    "./circleMembers":  "./src/circleMembers.js",
    "./followUp":       "./src/followUp.js",
    "./deliveryState":  "./src/deliveryState.js",
    "./kringBroadcast": "./src/kringBroadcast.js",
    "./mappingsStore":  "./src/mappingsStore.js",
    "./objectVersionsStorage": "./src/objectVersionsStorage.js",
    "./mappingsLoader":        "./src/mappingsLoader.js",
    "./circleSkills":     "./src/circleSkills.js",
    "./circleHop":        "./src/circleHop.js",
    "./findSkillMatches": "./src/findSkillMatches.js",
    "./hopPrompt":        "./src/hopPrompt.js",
    "./findExtras":       "./src/findExtras.js"
  },
  "scripts": {
    "test":       "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@onderling/item-store": "workspace:*",
    "@onderling/item-types": "workspace:*",
    "@onderling/pod-routing": "workspace:*",
    "@onderling/versioning": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  }
}
