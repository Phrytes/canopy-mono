{
  "private": true,
  "name": "@canopy/sync-engine",
  "version": "0.4.0",
  "description": "Pod ↔ external-source bidirectional sync engine. Composes core.DataSource / pod-client.PodClient. Post-Phase 5.1: V0 SyncEngine deleted; only the Folio-lifted bidirectional engine + scan/diff helpers remain.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".":           "./src/index.js",
    "./SyncEngine": "./src/SyncEngine.js",
    "./adapters":   "./src/adapters/index.js",
    "./adapters/*": "./src/adapters/*.js",
    "./PathMap":    "./src/PathMap.js",
    "./scanLocal":  "./src/scanLocal.js",
    "./scanPod":    "./src/scanPod.js",
    "./diff":       "./src/diff.js",
    "./objectDiff": "./src/objectDiff.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@canopy/core": "file:../core",
    "@canopy/pseudo-pod": "file:../pseudo-pod",
    "@canopy/versioning": "file:../versioning",
    "chokidar":       "^3.6.0"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "expo-crypto": "*",
    "expo-file-system": "*"
  },
  "peerDependenciesMeta": {
    "expo-crypto": {
      "optional": true
    },
    "expo-file-system": {
      "optional": true
    }
  }
}
