# Flat node_modules (npm-style), NOT pnpm's isolated .pnpm symlink store. Required: the apps pull in
# workspace packages via `file:../<pkg>`, and several of those packages use RELATIVE cross-package
# imports (e.g. basis's `../../packages/sync-engine/...`). The isolated store copies a file: dep
# into .pnpm and those relative paths break; a hoisted/flat tree keeps packages at their real
# locations so Metro/Vite resolve them. Matches the pre-existing layout (empty .pnpm + flat node_modules).
node-linker=hoisted

# Per-package lockfiles (apps/<app>/pnpm-lock.yaml) instead of one root lockfile — matches the existing
# committed layout (the leaf apps each carry their own pnpm-lock.yaml; library packages are linked).
shared-workspace-lockfile=false

# Link a matching workspace package even when the dependency spec is a plain version / "*" / file:
# (not the `workspace:` protocol). Several internal packages reference e.g. @canopy/webid-discovery as
# "*" or file:../webid-discovery; without this pnpm tries the registry and 404s.
link-workspace-packages=true
