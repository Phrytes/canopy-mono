{
  "name": "canopy-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "@onderling/* packages + mesh-demo example app",
  "type": "module",
  "scripts": {
    "test": "npm run test --prefix packages/core && npm run test --prefix packages/react-native && npm run test --prefix packages/relay && npm run test --prefix packages/pod-client && npm run test --prefix packages/integration-tests",
    "test:core": "npm run test --prefix packages/core",
    "test:rn": "npm run test --prefix packages/react-native",
    "test:relay": "npm run test --prefix packages/relay",
    "test:pod-client": "npm run test --prefix packages/pod-client",
    "test:scenarios": "npm run test --prefix packages/integration-tests",
    "demo": "node examples/mesh-demo/index.js",
    "demo:verify": "node examples/mesh-demo/index.js",
    "relay:start": "npm run start --prefix packages/relay",
    "lint:docs": "node scripts/lint-doc-refs.mjs",
    "lint:deps": "node scripts/lint-dep-boundaries.mjs",
    "lint:deps:update": "node scripts/lint-dep-boundaries.mjs --update",
    "test:deps": "vitest run scripts/lint-dep-boundaries.test.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@playwright/test": "^1.60.0",
    "playwright": "^1.60.0"
  }
}
