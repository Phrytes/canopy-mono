node_modules/
*.agentnet.yaml
.env
.vercel

# editor / os
.obsidian/
.~lock.*#
.DS_Store

# personal
session-notes/
.claude/

# large assets kept out of git
Architectural Design/*.pdf
apps/*/error.*

# Expo / RN build artifacts (regenerated by `expo run:android` etc.)
apps/*/.expo/
apps/*/android/build/
apps/*/android/app/build/
apps/*/android/.gradle/
apps/*/android/.idea/
apps/*/android/local.properties
apps/*/ios/build/
apps/*/ios/Pods/

# Same for SDK packages that ship native modules (currently react-native).
packages/*/android/build/
packages/*/android/app/build/
packages/*/android/.gradle/
packages/*/android/.idea/
packages/*/android/local.properties
packages/*/ios/build/
packages/*/ios/Pods/

# Vitest / vite / test runner artifacts
**/.vitest-cache/
**/coverage/

# Playwright / Detox test artifacts (regenerated each run)
playwright-report/
test-results/

# Android debug signing key — auto-generated, not a secret, but a binary
# that shouldn't be version-controlled (regenerates on first build).
**/debug.keystore

# Common log / temp files
*.log
*.tmp
.DS_Store

# Sub-agent worktree artifacts — Edit smoke-test files left behind because the
# harness sandbox blocks rm/find -delete in agent worktrees.  Harmless but they
# accumulate in `.claude/worktrees/agent-*/`; ignoring them here covers any
# stray copies that escape into the main tree too.
**/.preflight-*

# Whole android/ tree under folio-mobile is generated on first run
apps/folio-mobile/android/
# sdk-smoke android/ is also generated on first `expo run:android`
apps/sdk-smoke/android/

# Firebase credentials — required for expo-notifications on Android dev builds
# (see packages/react-native/docs/BRING-UP-NOTES.md Trap 18).  google-services.json
# is per-app + per-Firebase-project; the service-account JSON unlocks FCM v1 send.
apps/*/google-services.json
apps/*/firebase-service-account.json
apps/*/firebase-credentials.json

# Generated publish artifact: clean copy made by maak-publieke-kopie.sh.
# Source of truth is outreach/site/; this dir is rebuilt on each publish.
outreach/site-publiek/
# Same for the v2 site's generated publish copy + its zipped bundle.
outreach/onderling-v2-publiek/
# Zipped bundles/exports don't belong in git history (binary, non-diffable,
# regenerable). Commit the unzipped source instead if it needs versioning.
*.zip

# ─────────────────────────────────────────────────────────────────────────────
# Project docs — private-by-function (task #66 file-org model).
# See plans/PLAN-file-org-inventory.md. Living plans/notes + the frozen archive
# stay LOCAL (one Obsidian vault) and never reach the public remote. Tracked docs
# are docs/**, root README/QUICKSTART, and CLAUDE.md/AGENTS.md (any dir).
# Guard: scripts/lint-doc-refs.mjs (npm run lint:docs).
# ─────────────────────────────────────────────────────────────────────────────
plans/
_archive/
# Loose private docs at repo root — function is encoded in the name prefix.
/PLAN-*.md
/DESIGN-*.md
/CODING-*.md
/VOORSTEL-*.md
/PROPOSAL-*.md
/NOTE-*.md
/WIP-*.md
/BRIEF-*.md
/REMAINING-WORK.md
/PROGRESS.md
