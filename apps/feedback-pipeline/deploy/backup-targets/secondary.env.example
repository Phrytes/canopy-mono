# A SECOND target on a DIFFERENT provider, for redundancy (multi-cloud). Copy to
# `secondary.env`. Each target is backed up + verified independently. Example: Backblaze B2.
# (Any restic backend works: b2:, s3:, gs:, azure:, sftp:, rest:, a local/another-host path…)
RESTIC_REPOSITORY=b2:my-fp-secondary
RESTIC_PASSWORD=change-me-different-passphrase
B2_ACCOUNT_ID=replace-me
B2_ACCOUNT_KEY=replace-me
