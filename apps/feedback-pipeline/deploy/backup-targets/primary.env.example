# A restic backup TARGET. Copy to `primary.env` (NOT committed) and fill in. restic encrypts
# client-side with RESTIC_PASSWORD, so the store never sees plaintext. Pick an EU region.
# Example: AWS S3 (or any S3-compatible store).
RESTIC_REPOSITORY=s3:s3.eu-central-1.amazonaws.com/my-fp-primary
RESTIC_PASSWORD=change-me-strong-passphrase
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
