# Copy to deploy/.env and fill in. Never commit the real .env.

# public hostnames (DNS A/AAAA → this host; Caddy gets TLS for them)
PODS_HOST=pods.example.org
ACTIVATE_HOST=activate.example.org

# Privatemode (Edgeless) — the TEE LLM route. Obtain a project key from Edgeless.
PRIVATEMODE_API_KEY=replace-me

# Project-pod owner (the intermediary/steward). Create this account + client-credentials on
# the CSS once at bootstrap (see the runbook), then paste them here.
FP_OWNER_CLIENT_ID=replace-me
FP_OWNER_CLIENT_SECRET=replace-me
FP_OWNER_WEBID=https://pods.example.org/project/profile/card#me
FP_PROJECT_POD=https://pods.example.org/project/

# backup sidecar interval in seconds (default daily). Targets go in backup-targets/*.env.
BACKUP_INTERVAL=86400
