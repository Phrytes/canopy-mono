{
  "name":        "@canopy-app/canopy-chat",
  "version":     "0.1.0-dev",
  "private":     true,
  "description": "canopy-chat — command-first unified chat shell consuming canopy app manifests.  Static web app; mesh agent runs browser-side via relay + NKN + WebRTC.",
  "type":        "module",
  "main":        "src/index.js",
  "exports": {
    ".":                "./src/index.js",
    "./manifest":       "./manifest.js",
    "./parser":         "./src/parser.js",
    "./manifestMerge":  "./src/manifestMerge.js",
    "./router":         "./src/router.js",
    "./dispatch":       "./src/dispatch.js",
    "./renderer":       "./src/renderer.js",
    "./thread":         "./src/thread.js",
    "./threadStore":    "./src/threadStore.js",
    "./filter":         "./src/filter.js",
    "./events":         "./src/events.js",
    "./localisation":   "./src/localisation.js",
    "./locales/en":     "./locales/en.json",
    "./locales/nl":     "./locales/nl.json"
  },
  "scripts": {
    "test":       "vitest run",
    "test:watch": "vitest",
    "dev":        "vite",
    "build":      "vite build",
    "preview":    "vite preview"
  },
  "dependencies": {
    "@canopy/app-manifest": "file:../../packages/app-manifest",
    "@canopy/core":         "file:../../packages/core",
    "@canopy/vault":        "file:../../packages/vault",
    "i18next":              "^23.15.0"
  },
  "devDependencies": {
    "vitest":    "^3.0.0",
    "vite":      "^5.4.0",
    "happy-dom": "^15.0.0",
    "events":    "^3.3.0"
  }
}
