{
  "name": "@canopy-app/canopy-chat",
  "version": "0.1.0-dev",
  "private": true,
  "description": "canopy-chat — command-first unified chat shell consuming canopy app manifests.  Static web app; mesh agent runs browser-side via relay + NKN + WebRTC.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./manifest": "./manifest.js",
    "./parser": "./src/parser.js",
    "./manifestMerge": "./src/manifestMerge.js",
    "./router": "./src/router.js",
    "./dispatch": "./src/dispatch.js",
    "./renderer": "./src/renderer.js",
    "./thread": "./src/thread.js",
    "./threadStore": "./src/threadStore.js",
    "./filter": "./src/filter.js",
    "./events": "./src/events.js",
    "./bulkOps": "./src/bulkOps.js",
    "./followUps": "./src/followUps.js",
    "./embed": "./src/embed.js",
    "./syncHints": "./src/syncHints.js",
    "./appRegistry": "./src/appRegistry.js",
    "./externalFlow": "./src/externalFlow.js",
    "./brief": "./src/brief.js",
    "./find":  "./src/find.js",
    "./eventLog": "./src/eventLog.js",
    "./forms": "./src/forms/buildFormSpec.js",
    "./storage/local": "./src/storage/local.js",
    "./storage/podSync": "./src/storage/podSync.js",
    "./localisation": "./src/localisation.js",
    "./locales/en": "./locales/en.json",
    "./locales/nl": "./locales/nl.json"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@canopy-app/calendar": "workspace:*",
    "@canopy/app-manifest": "workspace:*",
    "@canopy/core": "workspace:*",
    "@canopy/manifest-host": "workspace:*",
    "@canopy/vault": "workspace:*",
    "@inrupt/solid-client":               "^3.0.0",
    "@inrupt/solid-client-authn-browser": "^2.4.0",
    "i18next": "^23.15.0",
    "chrono-node": "^2.7.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "vite": "^5.4.0",
    "happy-dom": "^15.0.0",
    "fake-indexeddb": "^6.0.0",
    "events": "^3.3.0"
  }
}
