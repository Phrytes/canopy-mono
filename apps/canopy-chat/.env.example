# canopy-chat web (vite) — copy to `.env.local` and adjust.
#
# Cross-peer RELAY for the v2 circle app. Point it at a reachable relay server
# (packages/relay). For a laptop+phone LAN test use the laptop's LAN IP so the
# phone can reach it — NOT 127.0.0.1 (that's only the laptop itself).
#   LAN:   VITE_CIRCLE_RELAY_URL=ws://192.168.2.20:8787
#   local: VITE_CIRCLE_RELAY_URL=ws://127.0.0.1:8787
# With this set, the circle app brings up the relay even when the NKN CDN didn't
# load (transport-neutral / local-first). See docs/two-device-relay-run.md.
VITE_CIRCLE_RELAY_URL=ws://127.0.0.1:8787

# Optional: confidential LLM + embeddings (Privatemode loopback proxy). Leave the
# key empty when the proxy is keyless on loopback (it holds the project key).
# VITE_CIRCLE_LLM_BASEURL=http://localhost:8080
# VITE_CIRCLE_LLM_MODEL=gpt-oss-120b
# VITE_CIRCLE_EMBED_BASEURL=http://localhost:8080
# VITE_CIRCLE_EMBED_MODEL=qwen3-embedding-4b
# VITE_CIRCLE_LLM_APIKEY=
