// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`characterization: privacy.html > initial HTML snapshot (static privacy notice) 1`] = `
"<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Tasks — Privacy notice</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header>
    <nav>
      <a href="/">Workspace</a>
      <a href="/mine.html">My work</a>
      <a href="/review.html">Review</a>
      <a href="/dag.html">DAG</a>
      <a href="/crew.html">Crew</a>
      <a href="/inbox.html" id="nav-inbox">Inbox</a>
    </nav>
    <div id="actor"></div>
  </header>

  <main>
    <section id="picker">
      <label class="inline">
        Language:
        <select id="lang">
          <option value="en">English</option>
          <option value="nl">Nederlands</option>
        </select>
      </label>
    </section>

    <section id="notice">
      <h2 id="notice-title">Privacy notice — closed beta</h2>
      <div id="notice-body"><p class="empty">Loading…</p></div>
    </section>
  </main>

  <script type="module">
    import {
      callSkill, getActor, mountInboxBadge, escapeHtml,
    } from '/app.js';

    document.getElementById('actor').textContent = await getActor();
    mountInboxBadge(document.getElementById('nav-inbox'));

    async function refresh() {
      const lang = document.getElementById('lang').value;
      const r = await callSkill('getPrivacyNotice', { lang });
      const root = document.getElementById('notice-body');
      root.innerHTML = '';
      const items = r.items ?? [];
      if (items.length === 0) {
        root.innerHTML = '<p class="empty">(no notice content)</p>';
        return;
      }
      for (const item of items) {
        const h3 = document.createElement('h3');
        h3.textContent = item.heading;
        h3.style.marginTop = '1rem';
        h3.style.marginBottom = '0.3rem';
        h3.style.color = 'var(--fg)';
        h3.style.textTransform = 'none';
        h3.style.letterSpacing = 'normal';
        const p = document.createElement('p');
        p.textContent = item.body;
        p.style.fontSize = '0.95rem';
        p.style.color = 'var(--muted)';
        p.style.margin = '0';
        root.append(h3, p);
      }
    }

    document.getElementById('lang').addEventListener('change', refresh);
    await refresh();
  </script>
</body>
</html>
"
`;
