<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security config.

  Development-permissive: cleartext is allowed for ALL hosts because
  the NKN bootstrap RPC nodes (Bundle G2, #264 — 2026-05-27) are HTTP
  IPs that change over time, e.g. 172.245.30.19.  Without this the
  NKN client gets `CLEARTEXT communication not permitted by network
  security policy` on every seed-node lookup and never connects.

  Production hardening (future): swap to a per-host exemption list of
  the canonical NKN bootstrap nodes (or use only HTTPS-capable nodes
  via a custom rpcServerAddr), and keep the loopback exception for
  Detox + Metro.  For now the unrestricted permit matches the
  `usesCleartextTraffic="true"` pattern nkn-test apps use in their
  src/debug/AndroidManifest.xml.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
