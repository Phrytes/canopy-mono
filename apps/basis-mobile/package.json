{
  "name": "@onderling-app/basis-mobile",
  "version": "0.0.1",
  "private": true,
  "description": "basis for Android — composition shell that unifies tasks-v0 + stoop + folio + household + calendar over a shared InternalBus, rendered with RN. Per Project Files/basis/mobile-roadmap-2026-05-24.md (#222).",
  "main": "index.js",
  "scripts": {
    "android": "expo run:android",
    "start": "expo start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "ios": "expo run:ios",
    "detox:build": "detox build --configuration android.emu.release",
    "detox:test": "detox test --configuration android.emu.release",
    "detox:test:attached": "detox test --configuration android.attached.release",
    "build:web": "expo export --platform web --output-dir dist-web",
    "test:web": "playwright test",
    "test:web:headed": "playwright test --headed"
  },
  "dependencies": {
    "@onderling-app/calendar": "file:../calendar",
    "@onderling-app/basis": "file:../basis",
    "@onderling-app/folio": "file:../folio",
    "@onderling-app/stoop": "file:../stoop",
    "@onderling-app/tasks": "file:../tasks-v0",
    "@onderling/app-manifest": "file:../../packages/app-manifest",
    "@onderling/blob-gateway": "file:../../packages/blob-gateway",
    "@onderling/core": "file:../../packages/core",
    "@onderling/kring-host": "file:../../packages/kring-host",
    "onderling-feedback": "link:../../../feedback",
    "@onderling/local-store": "file:../../packages/local-store",
    "@onderling/manifest-host": "file:../../packages/manifest-host",
    "@onderling/oidc-session": "file:../../packages/oidc-session",
    "@onderling/oidc-session-rn": "file:../../packages/oidc-session-rn",
    "@onderling/react-native": "file:../../packages/react-native",
    "@onderling/secure-agent": "file:../../packages/secure-agent",
    "@onderling/vault": "file:../../packages/vault",
    "@onderling/versioning": "file:../../packages/versioning",
    "@onderling/web-adapter": "file:../../packages/web-adapter",
