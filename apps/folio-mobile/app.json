{
  "expo": {
    "name": "Folio",
    "slug": "folio-mobile",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "folio",
    "android": {
      "package": "ag.canopy.foliomobile",
      "permissions": [
        "android.permission.INTERNET"
      ]
    },
    "ios": {
      "bundleIdentifier": "ag.canopy.foliomobile",
      "supportsTablet": false
    },
    "plugins": [
      "expo-dev-client",
      "expo-secure-store"
    ]
  }
}
