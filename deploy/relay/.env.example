# @canopy/relay — deploy env template. Copy to the PaaS service's variables.
# Behind a PaaS proxy the relay runs PLAIN HTTP; the proxy terminates TLS, so the
# PUBLIC url is wss://<your-relay-domain>. Do NOT set TLS_CERT/TLS_KEY on a PaaS.

# Listen port. Railway/Fly/Render inject PORT automatically — only set this locally.
PORT=8787
HOST=0.0.0.0

# ── Media blob-gate (Cloudflare R2 / any S3-compatible). Leave unset to run a
#    messaging-only relay. Set ALL of these to enable the /blob-gate media edge. ──
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_BUCKET=canopy-media
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_REGION=auto
# BLOB_GATE_ROUTE=/blob-gate
# BLOB_GATE_TTL=60
# BLOB_GATE_SKILL=media.read
# Comma-separated actor ids (token subjects / webIds) allowed to grant + upload.
# DEFAULT empty = NOBODY (deny-by-default). A real deploy MUST set this.
# BLOB_GATE_UPLOADERS=

# ── Push wake (notifications). Set PUSH_PROVIDER=expo to enable Expo push. ──
# PUSH_PROVIDER=expo
# EXPO_ACCESS_TOKEN=

# The clients point at this relay via its public wss:// URL:
#   RelayTransport({ relayUrl: 'wss://<your-relay-domain>' })
# and the media edge is https://<your-relay-domain>/blob-gate :
#   VITE_CIRCLE_MEDIA_EDGE_URL=https://<your-relay-domain>/blob-gate
