# @canopy-app/companion-node — deploy env template.
# The companion connects OUT to the deployed relay and hosts folio's pod-file
# agent (+ optionally the media edge) for the user's own devices over the mesh.

# The deployed relay's PUBLIC ws/wss URL. REQUIRED for the hosted topology —
# without it the companion boots its OWN in-process relay (local/dev only).
COMPANION_RELAY_URL=wss://<your-relay-domain>

# Persistent identity vault (host keypair). Must be a MOUNTED VOLUME so the
# host's mesh identity is stable across restarts (devices trust it by address).
COMPANION_NODE_CONFIG_DIR=/data/companion

# Only used when COMPANION_RELAY_URL is unset (in-process relay mode).
# PORT=8787
# HOST=127.0.0.1
