{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "deploy/companion-node/Dockerfile"
  },
  "deploy": {
    "startCommand": "node apps/companion-node/src/boot.js",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "volumes": [
      { "mountPath": "/data/companion" }
    ]
  }
}
