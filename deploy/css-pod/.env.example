# Community Solid Server (the deployable Solid pod) — deploy env template.

# --- Pod-target decision (Frits): WAC vs ACP ---
# WAC (default; the repo's proven-green path — universalAccess works):
CSS_CONFIG=@css:config/file.json
# ACP (Inrupt/ACP posture; the repo has a proven direct .acr writer for it):
# CSS_CONFIG=@css:config/file-acp.json

# The PUBLIC base URL. CSS bakes this into every WebID/resource URL, so it MUST
# equal the deployed domain. Change it after you know the domain and REDEPLOY
# with fresh storage (changing base URL invalidates existing WebIDs).
CSS_BASE_URL=https://<your-pod-domain>/

# Persistent storage — must be a MOUNTED VOLUME (all pod data lives here).
CSS_ROOT_FILE_PATH=/data/pod

# Railway/Fly/Render inject PORT; locally CSS_PORT is used.
CSS_PORT=3000
# CSS_LOG_LEVEL=info
